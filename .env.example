ASTRO_V1_API_ENABLED=false
ASTRO_V1_CHAT_ENABLED=false
ASTRO_CONVERSATION_ORCHESTRATOR_ENABLED=false
ASTRO_DAILY_FREE_QUESTIONS=20

# Astro Reading V2 rollout flags
# Keep false in production until V2 is fully tested.
ASTRO_READING_V2_ENABLED=false
ASTRO_MEMORY_ENABLED=false
ASTRO_REMEDIES_ENABLED=false
ASTRO_MONTHLY_ENABLED=false

# Astro Reading V2 client UI flags
NEXT_PUBLIC_ASTRO_READING_V2_UI_ENABLED=false
NEXT_PUBLIC_ASTRO_VOICE_ENABLED=false

# Optional local LLM adapter
# Disabled by default. Do not enable on public hosting unless you control the local Ollama server.
ASTRO_LLM_PROVIDER=disabled
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Existing integration reminders
# Supabase:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# Upstash:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Legacy AI connector:
# GROQ_API_KEY=
# Oracle VM / Python astro engine:
# ASTRO_ENGINE_URL=
# Vercel:
# NEXT_PUBLIC_SITE_URL=
